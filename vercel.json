    { "src": "/poison-ivy-treatment-online(/)?", "headers": { "Location": "/poison-ivy-oak-treatment-online/" }, "status": 301 },
    { "src": "/speech-anxiety-treatment-online(/)?", "headers": { "Location": "/performance-anxiety-treatment-online/" }, "status": 301 },
    { "src": "/male-pattern-hairloss-treatment-online(/)?", "headers": { "Location": "/hair-loss-treatment-online/" }, "status": 301 },
    { "src": "/asthma-refill-online(/)?", "headers": { "Location": "/asthma-refills-online/" }, "status": 301 },
    { "src": "/gerd-refills-online(/)?", "headers": { "Location": "/acid-reflux-refills-online/" }, "status": 301 },

    { "src": "/ga/sinus-infection-treatment(/)?", "headers": { "Location": "/ga/sinus-infection-treatment-online/" }, "status": 301 },
    { "src": "/fl/flu-treatment-online(/)?", "headers": { "Location": "/fl/influenza-treatment-online/" }, "status": 301 },
    { "src": "/fl/covid-treatment-online(/)?", "headers": { "Location": "/fl/covid-19-treatment-online/" }, "status": 301 },
    { "src": "/tx/sinus-infection-online-treatment(/)?", "headers": { "Location": "/tx/sinus-infection-treatment-online/" }, "status": 301 },
    { "src": "/tx/flu-online-treatment(/)?", "headers": { "Location": "/tx/influenza-treatment-online/" }, "status": 301 },
    { "src": "/tx/yeast-infection-online-treatment(/)?", "headers": { "Location": "/tx/yeast-infection-treatment-online/" }, "status": 301 },
    { "src": "/tx/bv-online-treatment(/)?", "headers": { "Location": "/tx/bv-treatment-online/" }, "status": 301 },
    { "src": "/tx/migraine-refills-treatment-online(/)?", "headers": { "Location": "/tx/migraine-refills-online/" }, "status": 301 },
    { "src": "/ca/bacterial-vaginosis-treatment-online(/)?", "headers": { "Location": "/ca/bv-treatment-online/" }, "status": 301 },
    { "src": "/tn/flu-treatment-online(/)?", "headers": { "Location": "/tn/influenza-treatment-online/" }, "status": 301 },
    { "src": "/pa/flu-treatment-online(/)?", "headers": { "Location": "/pa/influenza-treatment-online/" }, "status": 301 },
    { "src": "/oh/flu-treatment-online(/)?", "headers": { "Location": "/oh/influenza-treatment-online/" }, "status": 301 },
    { "src": "/nc/flu-treatment-online(/)?", "headers": { "Location": "/nc/influenza-treatment-online/" }, "status": 301 },

    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "https://pepper-saxophone-p8le.squarespace.com/$1",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "SAMEORIGIN",
        "Referrer-Policy": "strict-origin-when-cross-origin"
      }
    }
  ]
}
