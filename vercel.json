{
  "framework": null,
  "buildCommand": "npm run build && rm -f out/404.html out/404/index.html out/routes-manifest.json out/_not-found/index.html out/_not-found.html",
  "outputDirectory": "out",
  "trailingSlash": true,
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "https://pepper-saxophone-p8le.squarespace.com/$1",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "SAMEORIGIN",
        "Referrer-Policy": "strict-origin-when-cross-origin"
      }
    }
  ]
}
